@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure authenticator app";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="mb-3">
    <h3 class="h5 fw-bold text-white mb-1">@ViewData["Title"]</h3>
    <div class="text-white-50 small">
        Secure your account using an authenticator application.
    </div>
</div>

<div class="about-card p-3 p-md-4">

    <p class="text-white-50">
        To use an authenticator app go through the following steps:
    </p>

    <ol class="text-white-50">

        <li class="mb-3">
            Download a two-factor authenticator app like
            <strong>Microsoft Authenticator</strong> for
            <a class="auth-link" href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a>
            and
            <a class="auth-link" href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a>,
            or
            <strong>Google Authenticator</strong> for
            <a class="auth-link" href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</a>
            and
            <a class="auth-link" href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
        </li>

        <li class="mb-4">

            <p>
                Scan the QR Code or enter this key into your authenticator app:
            </p>

            <div class="mb-3">
                <kbd class="px-3 py-2"
                     style="background:#000;border:1px solid rgba(255,255,255,.15);color:#22c55e">
                    @Model.SharedKey
                </kbd>
            </div>

            <div class="alert border mb-3"
                 style="background:rgba(13,110,253,.10);border-color:rgba(13,110,253,.35);color:rgba(255,255,255,.85)">
                Learn how to
                <a class="auth-link" href="https://go.microsoft.com/fwlink/?Linkid=852423">
                    enable QR code generation
                </a>.
            </div>

            <div class="d-flex justify-content-center mb-3">
                <div id="qrCode"
                     class="p-3 rounded"
                     style="background:white;width:fit-content"></div>
            </div>

            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>

        </li>

        <li>

            <p class="mb-3">
                After scanning the QR code, your authenticator app will generate a verification code.
                Enter the code below to confirm setup.
            </p>

            <div class="row">
                <div class="col-md-6">

                    <form id="send-code" method="post" class="control-dark">

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code"
                                   class="form-control custom-placeholder"
                                   autocomplete="off"
                                   placeholder="Please enter the code." />

                            <label asp-for="Input.Code"
                                   class="form-label">
                                Verification Code
                            </label>

                            <span asp-validation-for="Input.Code"
                                  class="text-danger small"></span>
                        </div>

                        <button type="submit"
                                class="w-100 btn btn-lg btn-emerald">
                            Verify
                        </button>

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mt-3"
                             role="alert"></div>

                    </form>

                </div>
            </div>

        </li>

    </ol>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}