@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="mb-3">
    <h3 class="h5 fw-bold text-white mb-1">@ViewData["Title"]</h3>
    <div class="text-white-50 small">Download your data or permanently delete your account.</div>
</div>

<div class="about-card p-3 p-md-4">

    <div class="text-white-50 mb-3">
        Your account contains personal data that you have given us. This page allows you to download or delete that data.
    </div>

    <div class="alert border mb-4"
         style="background: rgba(220,53,69,.12); border-color: rgba(220,53,69,.35); color: rgba(255,255,255,.85);">
        <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <form id="download-data" asp-page="DownloadPersonalData" method="post" class="m-0">
            <button class="btn btn-emerald" type="submit">
                Download
            </button>
        </form>

        <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger">
            Delete account
        </a>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}