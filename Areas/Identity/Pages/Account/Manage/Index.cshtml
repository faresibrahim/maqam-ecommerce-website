@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="mb-3">
    <h3 class="h5 fw-bold text-white mb-1">@ViewData["Title"]</h3>
    <div class="text-white-50 small">Update your personal account information.</div>
</div>

<div class="about-card p-3 p-md-4">
    <form id="profile-form" method="post" class="control-dark">

        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Username"
                   class="form-control custom-placeholder"
                   placeholder="Please choose your username."
                   disabled />
            <label asp-for="Username" class="form-label"></label>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.PhoneNumber"
                   class="form-control custom-placeholder"
                   placeholder="Please enter your phone number." />
            <label asp-for="Input.PhoneNumber" class="form-label"></label>
            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
        </div>

        <button id="update-profile-button"
                type="submit"
                class="w-100 btn btn-lg btn-emerald">
            Save changes
        </button>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}