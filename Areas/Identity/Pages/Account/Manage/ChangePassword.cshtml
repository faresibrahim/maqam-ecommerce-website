@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="mb-3">
    <h3 class="h5 fw-bold text-white mb-1">@ViewData["Title"]</h3>
    <div class="text-white-50 small">Use a strong password to keep your account secure.</div>
</div>

<div class="about-card p-3 p-md-4">
    <form id="change-password-form" method="post" class="control-dark">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.OldPassword"
                   class="form-control custom-placeholder"
                   placeholder="Please enter your old password." />
            <label asp-for="Input.OldPassword" class="form-label"></label>
            <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.NewPassword"
                   class="form-control custom-placeholder"
                   placeholder="Please enter your new password." />
            <label asp-for="Input.NewPassword" class="form-label"></label>
            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.ConfirmPassword"
                   class="form-control custom-placeholder "
                   
                   placeholder="Please confirm your new password." />
            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="w-100 btn btn-lg btn-emerald">
            Update password
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}