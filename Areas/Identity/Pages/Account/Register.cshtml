@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-surface py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">

               

                <div class="auth-card">
                    <div class="p-4 p-md-5">
                        <div class="mb-4">
                            <h1 class="h3 mb-1 fw-bold text-white">@ViewData["Title"]</h1>
                            <p class="text-white-50 mb-0">Create your account to start browsing and listing items.</p>
                        </div>

                        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="vstack gap-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                            <div class="form-floating">
                                <input asp-for="Input.Email"
                                       class="form-control custom-placeholder"
                                       placeholder="name@example.com" />
                                <label asp-for="Input.Email" class="form-label">Email</label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="form-floating">
                                <input asp-for="Input.Password"
                                       class="form-control custom-placeholder"
                                       placeholder="password" />
                                <label asp-for="Input.Password" class="form-label">Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="form-floating">
                                <input asp-for="Input.ConfirmPassword"
                                       class="form-control custom-placeholder"
                                       placeholder="password" />
                                <label asp-for="Input.ConfirmPassword" class="form-label">Confirm password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button id="registerSubmit" type="submit" class="btn btn-emerald btn-lg w-100">
                                Create account
                            </button>

                            <div class="text-center text-white-50 small">
                                Already have an account?
                                <a class="auth-link"
                                   asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                                    Log in
                                </a>
                            </div>
                        </form>

                        <hr class="my-4" style="border-color: rgba(255,255,255,0.12);" />

                        <section>
                            <h2 class="h6 fw-semibold mb-3 text-white">Or register with</h2>

                            @{
                                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <div class="alert alert-dark border small mb-0"
                                         style="border-color: rgba(255,255,255,0.12); background: rgba(0,0,0,0.25); color: rgba(255,255,255,0.75);">
                                        No external login providers configured.
                                        See this
                                        <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="auth-link">
                                            article
                                        </a>
                                        to set it up.
                                    </div>
                                }
                                else
                                {
                                    <form id="external-account"
                                          asp-page="./ExternalLogin"
                                          asp-route-returnUrl="@Model.ReturnUrl"
                                          method="post">
                                        <div class="d-grid gap-2">
                                            @foreach (var provider in Model.ExternalLogins!)
                                            {
                                                <button type="submit"
                                                        class="btn btn-outline-light"
                                                        name="provider"
                                                        value="@provider.Name"
                                                        title="Register using your @provider.DisplayName account">
                                                    Continue with @provider.DisplayName
                                                </button>
                                            }
                                        </div>
                                    </form>
                                }
                            }
                        </section>
                    </div>
                </div>

                <p class="text-center text-white-50 small mt-4 mb-0">
                    <a class="text-decoration-none text-white-50"
                       asp-area="" asp-controller="Home" asp-action="Landing">← Back to Home</a>
                </p>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}