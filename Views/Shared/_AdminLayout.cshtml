<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Musical Instruments Online Store</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/custom.css">
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body class="admin-body">

    <div class="admin-shell">

        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-brand">
                <a asp-controller="Home" asp-action="Landing" class="admin-brand-link">
                    <span class="admin-brand-logo">M</span>
                    <span>Admin Panel</span>
                </a>
            </div>

            <nav class="admin-nav">

                <a asp-controller="AdminOperations" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </a>

                <a asp-controller="Category" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                    <i class="bi bi-tags-fill"></i>
                    <span>Categories</span>
                </a>

                <a asp-controller="Stock" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>Stock</span>
                </a>

                <a asp-controller="AdminOperations" asp-action="AllOrders"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                    <i class="bi bi-receipt-cutoff"></i>
                    <span>Orders</span>
                </a>

                <a asp-controller="Product" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                    <i class="bi bi-music-note-beamed"></i>
                    <span>Products</span>
                </a>

            </nav>

            <div class="admin-sidebar-footer">
                <a asp-controller="Home" asp-action="Landing" class="admin-nav-link">
                    <i class="bi bi-house-door-fill"></i>
                    <span>Back to Store</span>
                </a>
            </div>
        </aside>

        <!-- Main -->
        <div class="admin-main">

            <!-- Topbar -->
            <header class="admin-topbar">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn admin-menu-btn d-lg-none" type="button" onclick="toggleAdminSidebar()">
                        <i class="bi bi-list"></i>
                    </button>

                    <div>
                        <h1 class="admin-page-title mb-0">
                            @(ViewData["Title"] ?? "Admin")
                        </h1>
                    </div>
                </div>

               
            </header>

            <!-- Content -->
            <main class="admin-content">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleAdminSidebar() {
            document.getElementById('adminSidebar').classList.toggle('show');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>