@model IEnumerable<Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Products";
}

<div class="page-surface py-4">
    <div class="container">

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h1 class="h4 fw-bold text-white mb-1">Products</h1>
                <div class="text-white-50 small">Manage products and inventory items.</div>
            </div>

            <a asp-action="AddProduct"
               asp-controller="Product"
               class="btn btn-emerald">
                Add Product
            </a>
        </div>

        <div class="cart-card p-3 p-md-4">
            @if (Model != null && Model.Any())
            {
                <table class="table table-dark mb-0"
                       style="--bs-table-bg: transparent; --bs-table-striped-bg: rgba(255,255,255,.03);">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Product</th>
                            <th>Description</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(product.Image))
                                    {
                                        <img src="/Images/NoImage.png"
                                             alt="product image"
                                             style="width:70px;height:90px;object-fit:cover;border-radius:8px;background:#f8f9fa;padding:4px;" />
                                    }
                                    else
                                    {
                                        <img src="/images/@product.Image"
                                             alt="product image"
                                             style="width:70px;height:90px;object-fit:cover;border-radius:8px;background:#f8f9fa;padding:4px;" />
                                    }
                                </td>

                                <td class="text-white fw-semibold">
                                    @product.ProductName
                                </td>

                                <td class="text-white-50">
                                    @product.Description
                                </td>

                                <td class="text-white-50">
                                    @product.Category.CategoryName
                                </td>

                                <td class="text-white fw-semibold">
                                    @product.Price ₪
                                </td>

                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a asp-action="UpdateProduct"
                                           asp-controller="Product"
                                           asp-route-id="@product.ProductId"
                                           class="btn btn-emerald-outline btn-sm">
                                            Edit
                                        </a>

                                        <a asp-action="DeleteProduct"
                                           asp-controller="Product"
                                           asp-route-id="@product.ProductId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return window.confirm('Are you sure you want to delete this product?')">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <h2 class="h5 fw-bold text-white mb-2">No Products Found</h2>
                    <p class="text-white-50 mb-0">Start by adding your first product.</p>
                </div>
            }
        </div>

    </div>
</div>