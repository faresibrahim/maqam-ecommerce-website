@model IEnumerable<Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Categories";
}

<div class="page-surface py-4">
    <div class="container">

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h1 class="h4 fw-bold text-white mb-1">Categories</h1>
                <div class="text-white-50 small">Manage product categories.</div>
            </div>

            <a asp-action="AddCategory"
               asp-controller="Category"
               class="btn btn-emerald">
                Add Category
            </a>
        </div>

        <div class="cart-card p-3 p-md-4">
            @if (Model != null && Model.Any())
            {
                <table class="table table-dark mb-0"
                       style="--bs-table-bg: transparent; --bs-table-striped-bg: rgba(255,255,255,.03);">
                    <thead>
                        <tr>
                            <th style="width:70%;">Category</th>
                            <th style="width:30%;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td class="text-white fw-semibold">
                                    @category.CategoryName
                                </td>

                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a asp-action="UpdateCategory"
                                           asp-controller="Category"
                                           asp-route-id="@category.CategoryId"
                                           class="btn btn-emerald-outline btn-sm">
                                            Edit
                                        </a>

                                        <a asp-action="DeleteCategory"
                                           asp-controller="Category"
                                           asp-route-id="@category.CategoryId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return window.confirm('Are you sure you want to delete this category?')">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <h2 class="h5 fw-bold text-white mb-2">No Categories Found</h2>
                    <p class="text-white-50 mb-0">Start by adding your first category.</p>
                </div>
            }
        </div>

    </div>
</div>