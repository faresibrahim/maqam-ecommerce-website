@model CategoryDTO

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Category";
}

<div class="admin-card" style="max-width: 520px;">

    <div class="d-flex justify-content-between align-items-end gap-2 mb-4">
        <div>
            <div class="admin-card-title">Add Category</div>
            <div class="admin-card-subtitle">Create a new product category.</div>
        </div>

        <a asp-action="Index"
           asp-controller="Category"
           class="btn btn-admin-outline">
            Back
        </a>
    </div>

    <form asp-action="AddCategory" method="post" class="admin-form">
        <div class="form-floating mb-3">
            <input type="text"
                   class="form-control custom-placeholder"
                   asp-for="CategoryName"
                   placeholder="Insert category name" />
            <label asp-for="CategoryName">Category</label>
            <span asp-validation-for="CategoryName" class="text-danger small"></span>
        </div>

        <div class="form-floating mb-3">
            <input type="text"
                   class="form-control custom-placeholder"
                   asp-for="Icon"
                   placeholder="Insert icon as text" />
            <label asp-for="Icon">Icon</label>
            <span asp-validation-for="Icon" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-admin w-100">
            Add Category
        </button>
    </form>

</div>