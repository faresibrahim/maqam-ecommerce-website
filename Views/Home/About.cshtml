@{
    ViewData["Title"] = "About Us";
}

<section class="py-5 bg-maqam-dark-2 text-white">
    <div class="container">

        <!-- Header -->
        <div class="mb-5">
            <div class="section-label">Who we are</div>
            <h1 class="section-title" style="margin-bottom: 0.5rem;">About Maqam</h1>
            <p class="about-muted" style="font-size: 1rem; max-width: 520px; line-height: 1.8;">
                A Palestinian-built platform dedicated entirely to musical instruments —
                designed with musicians in mind, from the first listing to the final sale.
            </p>
        </div>

        <!-- Story + How it works -->
        <div class="row align-items-stretch g-4 mb-4">

            <div class="col-md-6">
                <div class="about-card p-4 p-md-5 h-100">
                    <h3 class="fw-semibold mb-3">Our Story</h3>
                    <p class="about-muted mb-3">
                        Maqam started with a simple observation: musicians in the West Bank had
                        no dedicated space to buy and sell instruments. Generic classifieds were
                        cluttered and untrustworthy. Social media posts got buried.
                    </p>
                    <p class="about-muted mb-3">
                        We built Maqam to fill that gap — a focused, music-only digital shop
                        where every listing is reviewed by our team before it goes live,
                        so buyers know exactly what they're getting.
                    </p>
                    <p class="about-muted mb-0">
                        The name <strong class="text-white">Maqam (مقام)</strong> refers to the
                        melodic frameworks at the heart of Arabic music — a fitting name for a
                        platform rooted in the musical culture of Palestine.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="about-card p-4 p-md-5 h-100">
                    <h3 class="fw-semibold mb-4">How Maqam works</h3>

                    <div class="d-flex gap-3 mb-4">
                        <div style="min-width: 36px; height: 36px; background: rgba(16,185,129,0.12);
                                    border: 1px solid rgba(16,185,129,0.3); border-radius: 8px;
                                    display:flex; align-items:center; justify-content:center;
                                    font-size: 0.75rem; color: #10b981; font-weight: 600;">
                            01
                        </div>
                        <div>
                            <div class="text-white fw-semibold mb-1" style="font-size: 0.9rem;">Sellers contact us</div>
                            <div class="about-muted" style="font-size: 0.8rem; line-height: 1.7;">
                                Individuals or music shops send us photos and details of the instrument they want to list.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mb-4">
                        <div style="min-width: 36px; height: 36px; background: rgba(16,185,129,0.12);
                                    border: 1px solid rgba(16,185,129,0.3); border-radius: 8px;
                                    display:flex; align-items:center; justify-content:center;
                                    font-size: 0.75rem; color: #10b981; font-weight: 600;">
                            02
                        </div>
                        <div>
                            <div class="text-white fw-semibold mb-1" style="font-size: 0.9rem;">We review and publish</div>
                            <div class="about-muted" style="font-size: 0.8rem; line-height: 1.7;">
                                Our team verifies the listing, writes a clean description, sets the price, and publishes it to the store.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <div style="min-width: 36px; height: 36px; background: rgba(16,185,129,0.12);
                                    border: 1px solid rgba(16,185,129,0.3); border-radius: 8px;
                                    display:flex; align-items:center; justify-content:center;
                                    font-size: 0.75rem; color: #10b981; font-weight: 600;">
                            03
                        </div>
                        <div>
                            <div class="text-white fw-semibold mb-1" style="font-size: 0.9rem;">Buyer purchases, we facilitate</div>
                            <div class="about-muted" style="font-size: 0.8rem; line-height: 1.7;">
                                When a buyer is ready, we coordinate the handoff between both parties and confirm the sale.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Values -->
        <div class="row text-center g-4 mb-4">
            <div class="col-md-4">
                <div class="about-card p-4 h-100">
                    <div class="mb-2">
                        <i class="bi bi-patch-check fs-3" style="color: #10b981;"></i>
                    </div>
                    <h5 class="fw-semibold mb-2">Reviewed listings</h5>
                    <p class="about-muted mb-0" style="font-size: 0.82rem; line-height: 1.75;">
                        Every instrument is checked by our team before it appears on the site.
                        No scams, no misleading photos.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card p-4 h-100">
                    <div class="mb-2">
                        <i class="bi bi-music-note-beamed fs-3" style="color: #10b981;"></i>
                    </div>
                    <h5 class="fw-semibold mb-2">Music-only focus</h5>
                    <p class="about-muted mb-0" style="font-size: 0.82rem; line-height: 1.75;">
                        Unlike general online shops, Maqam is built around instruments.
                        Every feature, every category, every detail is for musicians.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card p-4 h-100">
                    <div class="mb-2">
                        <i class="bi bi-geo-alt fs-3" style="color: #10b981;"></i>
                    </div>
                    <h5 class="fw-semibold mb-2">Local & trusted</h5>
                    <p class="about-muted mb-0" style="font-size: 0.82rem; line-height: 1.75;">
                        We operate within the West Bank. Buyers and sellers are local,
                        meetups are real, and the team is reachable.
                    </p>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="about-card p-4 p-md-5">
            <div class="row align-items-center g-3">
                <div class="col-md-8">
                    <h5 class="fw-semibold mb-1">Ready to browse or sell?</h5>
                    <p class="about-muted mb-0" style="font-size: 0.85rem;">
                        Whether you're looking for your next instrument or want to pass one on —
                        Maqam is the right place.
                    </p>
                </div>
                <div class="col-md-4 d-flex gap-2 flex-wrap justify-content-md-end">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-emerald px-4">
                        Browse Products
                    </a>
                    <a asp-controller="Home" asp-action="Landing" class="btn btn-outline-light px-4">
                        Back to Home
                    </a>
                </div>
            </div>
        </div>

    </div>
</section>
