@model ProductDisplayModel

@{
    ViewData["Title"] = "Products Page";
}

<div class="page-surface py-4">
    <div class="container">

        <!-- Filter / Search -->
        <div class="panel-dark p-3 p-md-4 mb-4 control-dark">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div>
                    <h1 class="h4 fw-bold mb-1 text-white">Browse Products</h1>
                    <div class="small text-white-50">Filter by category or search by title.</div>
                </div>
            </div>

            <form asp-action="Index" class="row row-cols-lg-auto g-3 align-items-center">
                <div class="col-12">
                    <label class="visually-hidden" for="CategoryId">Genres</label>
                    <select class="form-select" id="CategoryId" name="categoryId">
                        <option selected>Category</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option selected="@(category.CategoryId == Model.CategoryId)"
                                    value="@category.CategoryId">
                                @category.CategoryName
                            </option>
                        }
                    </select>
                </div>

                <div class="col-12">
                    <label class="visually-hidden" for="sterm">Search by title</label>
                    <input type="text"
                           class="form-control"
                           value="@Model.STerm"
                           id="sterm"
                           name="sterm"
                           placeholder="Search by title..." />
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-emerald px-4">
                        Search
                    </button>

                
                    <a href="~/Home/Index" class="btn btn-outline-light px-4">
                        Reset
                    </a>
                </div>
            </form>
        </div>

        <!-- Products Grid -->
        <div class="row g-3">
            @foreach (var product in Model.Products)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-3 d-flex">
                    <div class="product-card w-100 h-100 d-flex flex-column">

                        @if (string.IsNullOrEmpty(product.Image))
                        {
                            <img src="/images/NoImage.png"
                                 class="w-100"
                                 style="aspect-ratio: 1 / 1; object-fit: contain; padding: 14px;">
                        }
                        else
                        {
                            <img src="/images/@product.Image"
                                 class="w-100 product-img">
                        }

                        <div class="p-3 d-flex flex-column h-100">
                            <h4 class="fw-bold mb-2 text-truncate product-title" title="@product.ProductName">
                                @product.ProductName
                            </h4>

                            <div class="product-meta mb-2 text-truncate">
                                <span class="text-white-50">Category:</span> @product.CategoryName
                            </div>

                           

                            

                            @if(product.Quantity > 0)
                            {
                                <div class="text-white mb-3">
                                    <span class="text-white-50">Quantity:</span>
                                    <span class="fw-semibold">@product.Quantity </span>
                                </div>

                                <div class="text-white mb-3">
                                    <span class="text-white-50">Price:</span>
                                    <span class="fw-semibold">@product.Price ₪</span>
                                </div>

                                <div class="mt-auto">
                                    <button type="button"
                                            onclick="add(@product.ProductId)"
                                            class="btn btn-emerald w-100">
                                        Add to Cart
                                    </button>
                                </div>

                            }

                            else
                            {
                                <div class="mt-auto">
                                    <span class="border border-emerald text-emerald w-100 d-block text-center py-2 text-white">
                                        Out of Stock
                                    </span>
                                </div>
                            }


                          
                           
                        </div>

                    </div>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Make it global for inline onclick handlers
        window.add = async function (productId) {
            try {
                const response = await fetch(`/Cart/AddItem?productId=${productId}`);

                if (response.ok) {
                    const result = await response.json();

                    const cartCountEl = document.getElementById("cartCount");
                    if (cartCountEl) {
                        cartCountEl.innerHTML = result;
                        window.location.href = "#cartCount";
                    }
                } else {
                    console.log("Request failed:", response.status);
                }
            } catch (err) {
                console.log(err);
            }
        }
    </script>
}