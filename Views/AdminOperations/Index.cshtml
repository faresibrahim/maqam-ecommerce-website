@model DashboardModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="page-surface py-4">
    <div class="container">

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4">
            <div>
                <h1 class="h4 fw-bold text-white mb-1">Admin Dashboard</h1>
                <div class="text-white-50 small">Overview of your store activity and management tools.</div>
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-3 mb-4">

            <div class="col-md-6 col-xl-3">
                <div class="cart-card p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small mb-1">Total Products</div>
                            <div class="h3 fw-bold text-white mb-0">@Model.TotalProducts</div>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px;height:48px;background:rgba(34,197,94,.14);border:1px solid rgba(34,197,94,.35);">
                            <i class="bi bi-music-note-beamed text-white"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="cart-card p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small mb-1">Orders</div>
                            <div class="h3 fw-bold text-white mb-0">@Model.TotalOrders</div>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px;height:48px;background:rgba(59,130,246,.14);border:1px solid rgba(59,130,246,.35);">
                            <i class="bi bi-receipt text-white"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="cart-card p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small mb-1">Categories</div>
                            <div class="h3 fw-bold text-white mb-0">@Model.TotalCategories</div>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px;height:48px;background:rgba(168,85,247,.14);border:1px solid rgba(168,85,247,.35);">
                            <i class="bi bi-tags text-white"></i>
                        </div>
                    </div>
                </div>
            </div>


        </div>

        <!-- Quick actions -->
        <div class="row g-3 mb-4">

            <div class="col-lg-8">
                <div class="cart-card p-3 p-md-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h2 class="h5 fw-bold text-white mb-1">Quick Actions</h2>
                            <div class="text-white-50 small">Manage your store faster.</div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <a asp-controller="Product" asp-action="AddProduct"
                               class="text-decoration-none">
                                <div class="p-3 rounded-3 h-100"
                                     style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:42px;height:42px;background:rgba(34,197,94,.14);border:1px solid rgba(34,197,94,.35);">
                                            <i class="bi bi-plus-lg text-white"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-white">Add Product</div>
                                            <div class="text-white-50 small">Create a new product listing.</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="Category" asp-action="AddCategory"
                               class="text-decoration-none">
                                <div class="p-3 rounded-3 h-100"
                                     style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:42px;height:42px;background:rgba(59,130,246,.14);border:1px solid rgba(59,130,246,.35);">
                                            <i class="bi bi-tags text-white"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-white">Add Category</div>
                                            <div class="text-white-50 small">Organize products better.</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="Stock" asp-action="Index"
                               class="text-decoration-none">
                                <div class="p-3 rounded-3 h-100"
                                     style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:42px;height:42px;background:rgba(245,158,11,.14);border:1px solid rgba(245,158,11,.35);">
                                            <i class="bi bi-box-seam text-white"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-white">Manage Stock</div>
                                            <div class="text-white-50 small">Track and update inventory.</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="AdminOperations" asp-action="AllOrders"
                               class="text-decoration-none">
                                <div class="p-3 rounded-3 h-100"
                                     style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:42px;height:42px;background:rgba(168,85,247,.14);border:1px solid rgba(168,85,247,.35);">
                                            <i class="bi bi-receipt-cutoff text-white"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-white">View Orders</div>
                                            <div class="text-white-50 small">Manage customer orders.</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="cart-card p-3 p-md-4 h-100">
                    <h2 class="h5 fw-bold text-white mb-3">Store Summary</h2>

                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                        <span class="text-white-50">Paid Orders</span>
                        <span class="text-white fw-semibold">31</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                        <span class="text-white-50">Pending Orders</span>
                        <span class="text-white fw-semibold">11</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                        <span class="text-white-50">Out of Stock</span>
                        <span class="text-white fw-semibold">3</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-white-50">Estimated Revenue</span>
                        <span class="text-white fw-bold">12,450 ₪</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- Recent orders -->
        <div class="cart-card p-3 p-md-4">
            <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
                <div>
                    <h2 class="h5 fw-bold text-white mb-1">Recent Orders</h2>
                    <div class="text-white-50 small">Latest activity from customers.</div>
                </div>

                <a asp-controller="AdminOperations" asp-action="AllOrders" class="btn btn-emerald-outline btn-sm">
                    View All
                </a>
            </div>

            <table class="table table-dark mb-0"
                   style="--bs-table-bg: transparent; --bs-table-striped-bg: rgba(255,255,255,.03);">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Payment</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td class="text-white">#1001</td>
                        <td class="text-white-50">Ahmad Khalil</td>
                        <td class="text-white-50">08-03-2026</td>
                        <td>
                            <span class="badge"
                                  style="background: rgba(34,197,94,.14); border: 1px solid rgba(34,197,94,.35); color: #fff;">
                                Processing
                            </span>
                        </td>
                        <td>
                            <span class="badge"
                                  style="background: rgba(59,130,246,.14); border: 1px solid rgba(59,130,246,.35); color: #fff;">
                                COD
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-white">#1002</td>
                        <td class="text-white-50">Lina Nasser</td>
                        <td class="text-white-50">08-03-2026</td>
                        <td>
                            <span class="badge"
                                  style="background: rgba(255,193,7,.10); border: 1px solid rgba(255,193,7,.35); color: #fff;">
                                Pending
                            </span>
                        </td>
                        <td>
                            <span class="badge"
                                  style="background: rgba(220,53,69,.12); border: 1px solid rgba(220,53,69,.35); color: #fff;">
                                Unpaid
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-white">#1003</td>
                        <td class="text-white-50">Samer Odeh</td>
                        <td class="text-white-50">07-03-2026</td>
                        <td>
                            <span class="badge"
                                  style="background: rgba(168,85,247,.14); border: 1px solid rgba(168,85,247,.35); color: #fff;">
                                Shipped
                            </span>
                        </td>
                        <td>
                            <span class="badge"
                                  style="background: rgba(34,197,94,.14); border: 1px solid rgba(34,197,94,.35); color: #fff;">
                                Paid
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>