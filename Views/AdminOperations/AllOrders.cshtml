@model IEnumerable<Order>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "All Orders";
}

<div class="page-surface py-4">
    <div class="container">

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h1 class="h4 fw-bold text-white mb-1">All Orders</h1>
                <div class="text-white-50 small">Manage customer orders, payment status, and order progress.</div>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="cart-card p-3 p-md-4">
                <table class="table table-dark mb-0 orders-table"
                       style="--bs-table-bg: transparent; --bs-table-striped-bg: rgba(255,255,255,.03);">
                    <thead>
                        <tr>
                            <th>Order Date</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Mobile No</th>
                            <th>Address</th>
                            <th>Payment Status</th>
                            <th>Order Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="text-white">
                                    @order.CreatedAt.ToString("dd-MM-yyyy")
                                </td>

                                <td class="text-white fw-semibold">
                                    @order.Name
                                </td>

                                <td class="text-white-50 order-email">
                                    @order.Email
                                </td>

                                <td class="text-white-50">
                                    @order.MobileNumber
                                </td>

                                <td class="text-white-50 order-address">
                                    @order.Address
                                </td>

                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <span class="text-white-50 small">@order.PaymentMethod</span>

                                        @if (order.IsPaid)
                                        {
                                            <span class="badge"
                                                  style="background: rgba(34,197,94,.14); border: 1px solid rgba(34,197,94,.35); color: #fff; width: fit-content;">
                                                Paid
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge"
                                                  style="background: rgba(220,53,69,.12); border: 1px solid rgba(220,53,69,.35); color: #fff; width: fit-content;">
                                                Not Paid
                                            </span>
                                        }
                                    </div>
                                </td>

                                <td>
                                    <span class="badge"
                                          style="background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); color: #fff;">
                                        @order.OrderStatus.StatusName
                                    </span>
                                </td>

                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <button type="button" data-bs-toggle="modal" data-bs-target="#modal-@order.OrderId" class="btn btn-outline-light btn-sm">
                                            Order Detail
                                        </button>

                                        <a asp-action="UpdateOrderStatus"
                                           asp-route-orderId="@order.OrderId"
                                           class="btn btn-emerald-outline btn-sm">
                                            Change Order Status
                                        </a>

                                        <a asp-action="TogglePaymentStatus"
                                           asp-route-orderId="@order.OrderId"
                                           class="btn btn-emerald btn-sm">
                                            Toggle Payment Status
                                        </a>

                                        <a asp-action="RemoveOrder"
                                           asp-route-orderId="@order.OrderId"
                                           class="btn btn-emerald-outline btn-sm">
                                            Remove Order
                                        </a>

                                        @await Html.PartialAsync("/Views/AdminOperations/_OrderDetailModal.cshtml", new OrderDetailModelDTO{DivId =order.OrderId.ToString(),
                                        OrderDetails=order.OrderDetail})
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
                <div class="text-center">
                    <h1 class="fw-bold display-6 text-white mb-2">No Orders Found</h1>
                    <p class="cart-muted mb-0">There are currently no orders to manage.</p>
                </div>
            </div>
        }

    </div>
</div>