
@model StockDTO
@{
    Layout = "_AdminLayout";

    ViewData["Title"] = "Manage Stock";
}

<div class="page-surface py-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-end mb-3">
            <div>
                <h1 class="h4 fw-bold text-white mb-1">Manage Stock</h1>
                <div class="text-white-50 small">Update product inventory quantity.</div>
            </div>

            <a asp-action="Index" asp-controller="Stock" class="btn btn-emerald-outline">
                Back
            </a>
        </div>

        <div class="cart-card p-3 p-md-4" style="max-width:500px;">

            <form asp-action="ManangeStock" method="post" class="control-dark">

                <input type="hidden" asp-for="ProductId" />

                <div class="form-floating mb-3">
                    <input type="number"
                           class="form-control"
                           asp-for="Quantity"
                           placeholder="Quantity" />

                    <label asp-for="Quantity">Quantity</label>
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-emerald w-100">
                    Update Stock
                </button>

            </form>

        </div>

    </div>
</div>