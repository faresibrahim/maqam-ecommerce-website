@model IEnumerable<StockDisplayModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Stocks";
}

<div class="page-surface py-4">
    <div class="container">

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h1 class="h4 fw-bold text-white mb-1">Stocks</h1>
                <div class="text-white-50 small">Search products and manage current inventory.</div>
            </div>
        </div>

        <div class="cart-card p-3 p-md-4 mb-4">
            <form asp-action="Index" method="get" class="control-dark">
                <div class="row g-2 align-items-center">
                    <div class="col-md-4">
                        <input type="text"
                               name="sTerm"
                               class="form-control"
                               placeholder="Search by product" />
                    </div>

                    <div class="col-auto">
                        <button type="submit" class="btn btn-emerald">
                            Find
                        </button>
                    </div>

                    <div class="col-auto">
                        <a asp-action="Index" asp-controller="Stock" class="btn btn-outline-light">
                            Clear
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="cart-card p-3 p-md-4">
            @if (Model != null && Model.Any())
            {
                <table class="table table-dark mb-0"
                       style="--bs-table-bg: transparent; --bs-table-striped-bg: rgba(255,255,255,.03);">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Stock</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-white fw-semibold">
                                    @item.ProductName
                                </td>

                                <td>
                                    @if (item.Quantity <= 0)
                                    {
                                        <span class="badge"
                                              style="background: rgba(220,53,69,.12); border: 1px solid rgba(220,53,69,.35); color: #fff;">
                                            Out of Stock (@item.Quantity)
                                        </span>
                                    }
                                    else if (item.Quantity <= 5)
                                    {
                                        <span class="badge"
                                              style="background: rgba(255,193,7,.10); border: 1px solid rgba(255,193,7,.35); color: #fff;">
                                            Low Stock (@item.Quantity)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge"
                                              style="background: rgba(34,197,94,.14); border: 1px solid rgba(34,197,94,.35); color: #fff;">
                                            In Stock (@item.Quantity)
                                        </span>
                                    }
                                </td>

                                <td>
                                    <a asp-action="ManageStock"
                                       asp-controller="Stock"
                                       asp-route-productId="@item.ProductId"
                                       class="btn btn-emerald-outline btn-sm">
                                        Update Stock
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <h2 class="h5 fw-bold text-white mb-2">No stock records found</h2>
                    <p class="text-white-50 mb-0">Try a different search term or clear the filter.</p>
                </div>
            }
        </div>

    </div>
</div>